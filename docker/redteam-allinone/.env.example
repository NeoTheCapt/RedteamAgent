# Runtime secrets and API keys for the single-image OpenCode container.
# Copy to .env and pass with: docker run --env-file docker/redteam-allinone/.env ...

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

REDTEAM_RUNTIME_MODE=local
MSF_USER=msf
MSF_PASSWORD=msf
MSF_SERVER=127.0.0.1
MSF_PORT=55553
MSF_SSL=false
METASPLOIT_MCP_LOG_LEVEL=info
