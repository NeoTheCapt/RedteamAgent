!agent/.claude/agents/operator.md
!agent/.codex/agents/operator.toml

# ============================================
# agent/ is canonical; root-level duplicates of agent runtime are forbidden.
# Use agent/.opencode, agent/scripts, agent/skills, agent/references, agent/docker.
# To install the pre-commit guard: cp agent/scripts/hooks/block-root-dup-dirs.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# ============================================
/.opencode/
/scripts/
/skills/
/references/
/docker/
