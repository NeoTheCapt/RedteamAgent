# ============================================
# Claude Code / IDE (dev workspace)
# ============================================
/.claude/
/.codex/
/.worktrees/
/CLAUDE.md
/AGENTS.md
/opencode.json
/tools/
/tests/*
!/tests/
!/tests/agent-contracts/
!/tests/agent-contracts/**
docs/
/tmp/
/tmp-*/
/scratch/
/scratch-*/

# Track agent/.claude/ (runtime config) but ignore local overrides
!agent/.claude/

# ============================================
# Engagement artifacts (per-engagement, never commit)
# ============================================
agent/engagements/*/
!agent/engagements/.gitkeep
agent/engagements/.active

# ============================================
# Pentest tool output & artifacts
# ============================================

# nmap
*.nmap
*.gnmap
*.xml

# sqlmap
output/
.sqlmap/

# ffuf / gobuster / dirb
*.ffuf
*.gobuster

# Burp Suite
*.burp
*.jar

# Metasploit
*.rc
loot/
.msf4/

# Nuclei
nuclei-output/

# Nikto
*.csv

# Hydra / John / Hashcat
*.pot
*.restore
*.session

# General scan output
scan_results/
scan-results/
scans/

# ============================================
# Captured data & loot
# ============================================
loot/
dumps/
exfil/
*.dump
*.sql
!agent/scripts/schema.sql
*.bak
*.db
*.sqlite
*.sqlite3

# Credentials & wordlists (user-specific)
*.wordlist
creds/
credentials/

# Screenshots & evidence (large binaries)
screenshots/
*.png
*.jpg
*.jpeg
*.gif
*.bmp

# ============================================
# Generated scripts & payloads
# ============================================
payloads/
!agent/references/payloads/
exploits/
shells/
*.elf
*.exe
*.dll
*.so
*.war

# ============================================
# Node/TypeScript (plugin compilation)
# ============================================
node_modules/
*.js
*.d.ts
*.js.map
package-lock.json
yarn.lock

# ============================================
# OS & editor
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ============================================
# Misc runtime
# ============================================
*.log
*.tmp
*.temp
*.pid
*.cache
__pycache__/
*.pyc
.env
.env.*
!.env.example
!agent/.env.example

# ============================================
# CLI runtime files (local overrides, state, caches)
# ============================================

# Claude Code
agent/.claude/settings.local.json
agent/.claude/todos.json
agent/.claude/statsig/

# Codex
agent/.codex/config.toml
agent/.codex/state/

# Generated install-time build output
agent/build/
# Keep operator files (not generated by build)
!agent/.claude/agents/operator.md
!agent/.codex/agents/operator.toml
