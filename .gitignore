# local-openclaw: track shared tooling (scripts, prompts, skills, tests),
# ignore per-operator state (scheduler.env with tokens, cycle logs, findings).
# Note: must exclude `/local-openclaw/*` (not `/local-openclaw/`) so the
# negation rules below can re-include specific children. Git won't descend
# into a fully-excluded directory.
/local-openclaw/*
!/local-openclaw/scripts/
!/local-openclaw/prompts/
!/local-openclaw/requirements/
!/local-openclaw/skills/
!/local-openclaw/tests/
!/local-openclaw/launchd/
# But the generated .plist files are per-operator (labels like
# com.neothecapt.*) and are rewritten by manage_launchd.sh — the template
# lives in that script, so the artifacts themselves stay out of git.
/local-openclaw/launchd/*.plist
!/local-openclaw/README.md
/tests/
/orchestrator/tests/
/orchestrator/backend/data/
/orchestrator/backend/*.egg-info/
/.superpowers/brainstorm/
/.opencode/vendor/
docs/**
!docs/
!docs/redteam-agent-demo-fast.gif
!docs/screenshot-20260331-181406.png
/tmp/
.venv/
/tmp-*/
/scratch/
/scratch-*/

# Track agent/.claude/ (runtime config) but ignore local overrides
!agent/.claude/

# ============================================
# Engagement artifacts (per-engagement, never commit)
# ============================================
agent/engagements/*/
!agent/engagements/.gitkeep
agent/engagements/.active

